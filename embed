<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>
  html,body{
    margin:0;
    padding:0;
    height:100%;
    background:#000;
    color:#fff;
    font-family:sans-serif;
    box-sizing:border-box;
  }
  *,*::before,*::after{ box-sizing:inherit; }

  .app{
    width:100%;
    max-width:1000px;
    margin:0 auto;
    padding:0;
    border-radius:10px;
    overflow:visible;
  }

  .player{
    position:relative;
    width:100%;
    aspect-ratio:16/9;
    background:#000;
    border-radius:10px;
    overflow:visible;
    box-shadow:0 0 0 1px #000;
  }

  .player iframe{
    width:100%;
    height:100%;
    border:0;
    display:block;
    border-radius:10px;
  }
</style>
</head>
<body>

<div class="app">
  <div class="player" id="player">
    <iframe id="playerFrame"
      src="https://pone_tu_url"
      allow="encrypted-media; fullscreen"
      allowfullscreen
      title="Reproductor de streaming">
    </iframe>
  </div>
</div>

</body>
</html>
